<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme._2048Original" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">#0B0C10</item>
        <!-- Set the splash screen icon -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <!-- Post splash screen theme -->
        <item name="postSplashScreenTheme">@style/Theme._2048Original</item>
    </style>
</resources>